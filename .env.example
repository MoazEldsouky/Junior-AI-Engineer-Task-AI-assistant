# =============================================================================
# AI Agent Excel Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in at least ONE provider's API key.
#
# Get free API keys:
#   Gemini  → https://aistudio.google.com/apikey
#   Groq    → https://console.groq.com/keys
#   OpenRouter → https://openrouter.ai/keys
#   GitHub  → https://github.com/settings/tokens (with "models" scope)
# =============================================================================

# --- LLM Provider API Keys (at least one required) ---
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GITHUB_TOKEN=

# --- Active Provider ---
# Options: gemini | groq | openrouter | github_models
LLM_PROVIDER=github_models

# --- Model Override (optional — sensible defaults are built-in) ---
# LLM_MODEL=gemini-2.0-flash
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_MODEL=google/gemma-4-31b-it:free

LLM_MODEL=gpt-4o

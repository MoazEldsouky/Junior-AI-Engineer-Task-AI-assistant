# =============================================================================
# AI Agent Excel Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in at least ONE provider's API key.
# All parameters have sensible defaults built-in. Uncomment any variable 
# to override its default value.
# =============================================================================

# --- LLM Provider API Keys (at least one required) ---
# Get keys at:
# Gemini  → https://aistudio.google.com/apikey
# Groq    → https://console.groq.com/keys
# OpenRouter → https://openrouter.ai/keys
# GitHub  → https://github.com/settings/tokens (with "models" scope)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GITHUB_TOKEN=

# ── Active Provider & Model ──────────────────────────────────────────────────
# Provider options: gemini | groq | openrouter | github_models
LLM_PROVIDER=github_models
# Model Override (leave empty to use provider's best free-tier default)
# LLM_MODEL=gpt-4o

# ── LLM Generation ───────────────────────────────────────────────────────────
# LLM_TEMPERATURE=0
# LLM_MAX_TOKENS=2048
# LLM_REQUEST_TIMEOUT=60.0

# ── Retry & Resilience ───────────────────────────────────────────────────────
# LLM_MAX_RETRIES=3
# LLM_RETRY_BACKOFF=[3, 8, 15, 30, 60]

# ── Agent / ReAct Loop ───────────────────────────────────────────────────────
# MAX_AGENT_ITERATIONS=5
# MAX_OBSERVATION_ROWS=30
# MAX_HISTORY_MESSAGES=20

# ── Session Management ───────────────────────────────────────────────────────
# SESSION_TTL_MINUTES=60

# ── Server & API ─────────────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
# CORS_ORIGINS=["*"]

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s | %(levelname)-7s | %(name)s | %(message)s
# LOG_DATE_FORMAT=%H:%M:%S
